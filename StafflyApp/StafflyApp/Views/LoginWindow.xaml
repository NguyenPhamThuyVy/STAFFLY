<Window x:Class="StafflyApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="STAFFLY Login" Height="600" Width="920"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown" FontFamily="Segoe UI">

    <Border CornerRadius="20" Background="White" BorderBrush="#DDDDDD" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="20,0,0,20" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A237E" Offset="0"/>
                        <GradientStop Color="#FF2945FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Ellipse Width="300" Height="300" Fill="White" Opacity="0.1" Margin="-100,-100,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                    <Ellipse Width="200" Height="200" Fill="White" Opacity="0.1" Margin="0,0,-50,-50" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <Image Source="/Assets/Images/staffly_logo_white.png" 
                               Width="104" Height="97" 
                               Margin="0,0,0,0
                               " 
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"/>

                        <TextBlock Text="STAFFLY" 
                                   FontSize="40" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Intelligent HR Management" 
                                   FontSize="14" 
                                   Foreground="#D1C4E9" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="30,16,20,40">
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" Cursor="Hand">
                    <materialDesign:PackIcon Kind="Close" Foreground="#757575" Width="20" Height="20"/>
                </Button>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Sign In" FontSize="30" FontWeight="Bold" Foreground="#1A237E" Margin="0,0,0,0" HorizontalAlignment="Center"/>
                    <TextBlock Text="Welcome back! Please enter your details." FontSize="14" Foreground="#888" Margin="0,5,0,30" HorizontalAlignment="Center"/>

                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             materialDesign:HintAssist.Hint="Email / Username" 
                             Margin="0,0,0,20" FontSize="15" BorderThickness="2"
                             BorderBrush="#1A237E" materialDesign:TextFieldAssist.TextFieldCornerRadius="10"
                             materialDesign:HintAssist.Foreground="#1A237E"/>

                    <PasswordBox Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" 
                                 materialDesign:HintAssist.Hint="Password" 
                                 Margin="0,0,0,10" FontSize="15" BorderThickness="2"
                                 BorderBrush="#1A237E" materialDesign:TextFieldAssist.TextFieldCornerRadius="10"
                                 materialDesign:HintAssist.Foreground="#1A237E"/>

                    <TextBlock Text="Forgot password?" HorizontalAlignment="Right" Foreground="#757575" 
                               Cursor="Hand" TextDecorations="Underline" Margin="0,0,0,35"/>

                    <Button Content="SIGN IN" Foreground="White" Height="45" Click="LoginButton_Click" 
                            materialDesign:ButtonAssist.CornerRadius="22" FontWeight="Bold" Background="#FF203495"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>