<UserControl x:Class="StafflyApp.Views.AdminAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:StafflyApp.ViewModels"
             Background="Transparent" FontFamily="Segoe UI">

    <UserControl.DataContext>
        <vm:AdminAccountsViewModel/>
    </UserControl.DataContext>

    <Border Background="White" CornerRadius="25" Padding="30" Margin="10,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Account Management" FontSize="26" FontWeight="Bold" Foreground="#1A1C29"/>
                    <TextBlock Text="Provision operational credentials, roles, and functional status tokens." Foreground="#6B7280" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <Button HorizontalAlignment="Right" Command="{Binding OpenCreateAccountPopupCommand}"
                        Background="#1954D1" Foreground="White" BorderThickness="0" Height="45" Padding="20,0"
                        materialDesign:ButtonAssist.CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="CREATE ACCOUNT" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <DataGrid Grid.Row="1" ItemsSource="{Binding AccountsList}" AutoGenerateColumns="False" CanUserAddRows="False"
                      Style="{StaticResource MaterialDesignDataGrid}" BorderThickness="0" Background="White" RowHeight="45"
                      AlternatingRowBackground="#FAFBFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="200" FontWeight="SemiBold" Foreground="#1A1C29"/>
                    <DataGridTextColumn Header="Assigned Role" Binding="{Binding RoleName}" Width="150"/>
                    <DataGridTextColumn Header="Created Date" Binding="{Binding CreatedDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="220"/>

                    <DataGridTemplateColumn Header="Status (IsActive)" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ToggleButton IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"
                                              Command="{Binding DataContext.ToggleAccountStatusCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"
                                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                              VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Popup IsOpen="{Binding IsCreateAccountPopupOpen}" Placement="Center" 
                   PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}" AllowsTransparency="True" StaysOpen="False">
                <Border Background="White" Width="380" CornerRadius="16" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Color="#000" Opacity="0.1" ShadowDepth="5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🔐 New Credentials Provision" FontSize="18" FontWeight="Bold" Foreground="#1954D1" Margin="0,0,0,20"/>

                        <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Username" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,15"/>
                        <PasswordBox x:Name="NewPasswordBox" materialDesign:HintAssist.Hint="Secure Password" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Margin="0,0,0,15"/>

                        <ComboBox ItemsSource="{Binding RolesCollection}" SelectedItem="{Binding SelectedRole}" DisplayMemberPath="RoleName" 
                                  materialDesign:HintAssist.Hint="Select Role" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,25"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Cancel" Command="{Binding ClosePopupCommand}" Background="#E5E7EB" Foreground="#374151" BorderThickness="0" Height="40" Margin="0,0,5,0" materialDesign:ButtonAssist.CornerRadius="8"/>
                            <Button Grid.Column="1" Content="Create Profile" Click="CreateAccount_Click" Background="#1954D1" Foreground="White" FontWeight="Bold" BorderThickness="0" Height="40" Margin="5,0,0,0" materialDesign:ButtonAssist.CornerRadius="8"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>