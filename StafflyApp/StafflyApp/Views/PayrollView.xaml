<UserControl x:Class="StafflyApp.Views.PayrollView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent" FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="25" Padding="30" Margin="10,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Payroll Statistics" FontSize="26" FontWeight="Bold" Foreground="#1A1C29"/>
                <TextBlock Text="Import payroll data from Excel and submit it to Manager" Foreground="#6B7280" FontSize="14" Margin="0,5,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding ImportExcelCommand}" 
                        Background="#1954D1" Foreground="White" BorderThickness="0" 
                        Height="45" Padding="20,0" materialDesign:ButtonAssist.CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcel" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="SELECT EXCEL FILE" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Border Grid.Column="1" Background="#F3F4F6" CornerRadius="12" Margin="15,0" Padding="15,0">
                    <TextBlock Text="{Binding FilePath}" VerticalAlignment="Center" Foreground="#6B7280" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
                </Border>

                <Button Grid.Column="2" Command="{Binding SubmitToManagerCommand}" 
                        Visibility="{Binding IsDataLoaded, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="#1A365D" Foreground="White" BorderThickness="0" 
                        Height="45" Padding="25,0" materialDesign:ButtonAssist.CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Send" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="SUBMIT TO MANAGER" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <DataGrid Grid.Row="2" ItemsSource="{Binding ImportedRecords}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      BorderThickness="0" Background="White"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      AlternatingRowBackground="#FAFBFC">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                <Setter Property="Background" Value="#FFF1F2"/>
                                <Setter Property="Foreground" Value="#E11D48"/>
                                <Setter Property="ToolTip" Value="{Binding ErrorNote}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding EmployeeID}" Width="70"/>

                    <DataGridTemplateColumn Header="Employee Name" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30" Height="30" Background="#E0E7FF" CornerRadius="15" Margin="0,0,10,0">
                                        <materialDesign:PackIcon Kind="Account" Foreground="#1954D1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding EmployeeName}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1A1C29"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Period" Width="100">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0:D2}/{1}">
                                <Binding Path="Month"/>
                                <Binding Path="Year"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Basic Salary" Binding="{Binding TotalSalary, StringFormat={}{0:N0} USD}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,15,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Bonus" Binding="{Binding TotalBonus, StringFormat={}{0:N0} USD}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,15,0"/>
                                <Setter Property="Foreground" Value="#059669"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Status" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBadge" CornerRadius="10" Padding="10,2" HorizontalAlignment="Left">
                                    <TextBlock x:Name="StatusText" FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="True">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="#DCFCE7"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#15803D"/>
                                        <Setter TargetName="StatusText" Property="Text" Value="READY"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="#FFE4E6"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#BE123C"/>
                                        <Setter TargetName="StatusText" Property="Text" Value="ERROR"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Background="#F9FAFB" CornerRadius="12" Padding="15" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Foreground="#6B7280" FontSize="12" VerticalAlignment="Center">
                        <Run Text="Note: " FontWeight="Bold"/>
                        <Run Text="Rows with ERROR status will be automatically ignored by the system during the submission process to the Manager."/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>