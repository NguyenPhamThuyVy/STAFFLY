<UserControl x:Class="StafflyApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent" FontFamily="Segoe UI"
             MinHeight="600" MinWidth="1000">

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Welcome in, Nixtio" FontSize="32" FontWeight="Light" Foreground="#1A1C29" Margin="0,0,0,15"/>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Interviews" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5"/>
                        <Border Background="#1954D1" CornerRadius="12" Width="80" Height="24">
                            <TextBlock Text="25%" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Hired" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5"/>
                        <Border Background="#1954D1" CornerRadius="12" Width="80" Height="24">
                            <TextBlock Text="30%" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Border>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Project time" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5"/>
                        <Border Background="#1954D1" CornerRadius="12" Width="120" Height="24">
                            <TextBlock Text="45%" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <StackPanel Margin="20,0">
                    <TextBlock Text="92" FontSize="36" FontWeight="Medium" Foreground="#1A1C29" HorizontalAlignment="Center"/>
                    <TextBlock Text="Employee" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="20,0">
                    <TextBlock Text="75" FontSize="36" FontWeight="Medium" Foreground="#1A1C29" HorizontalAlignment="Center"/>
                    <TextBlock Text="Hirings" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="315" FontSize="36" FontWeight="Medium" Foreground="#1A1C29" HorizontalAlignment="Center"/>
                    <TextBlock Text="Projects" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Background="#94B9D2" CornerRadius="20" Height="250" Margin="0,0,0,15" Padding="20">
                    <Grid>
                        <materialDesign:PackIcon Kind="AccountCircle" Width="100" Height="100" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0"/>
                        <StackPanel VerticalAlignment="Bottom">
                            <TextBlock Text="Alex Chen" FontSize="20" FontWeight="Bold" Foreground="#1A1C29"/>
                            <TextBlock Text="UI/UX Designer" FontSize="14" Foreground="#4A5568" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Background="#1A365D" CornerRadius="15" HorizontalAlignment="Right" VerticalAlignment="Bottom" Padding="15,8">
                            <TextBlock Text="$1,500" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Background="White" CornerRadius="20" Padding="10">
                    <StackPanel>
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#1A1C29" HorizontalContentAlignment="Left" Height="40">
                            <Grid Width="250">
                                <TextBlock Text="Pension contributions" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <materialDesign:PackIcon Kind="ChevronDown" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#1A1C29" HorizontalContentAlignment="Left" Height="60">
                            <Grid Width="250">
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Devices" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <materialDesign:PackIcon Kind="Laptop" Foreground="#1954D1" Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="MacBook Air" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Version M1" FontSize="10" Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <materialDesign:PackIcon Kind="ChevronUp" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#1A1C29" HorizontalContentAlignment="Left" Height="40">
                            <Grid Width="250">
                                <TextBlock Text="Compensation Summary" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <materialDesign:PackIcon Kind="ChevronDown" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Column="1" Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="20" Height="250" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <TextBlock Text="Progress" FontSize="18" FontWeight="Medium" Foreground="#6B7280"/>
                        <StackPanel Margin="0,30,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="6.1 h" FontSize="36" FontWeight="SemiBold" Foreground="#1A1C29"/>
                                <TextBlock Text="Work Time&#x0a;this week" FontSize="11" Foreground="#6B7280" Margin="10,0,0,5" VerticalAlignment="Bottom"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Height="100" Margin="0,20,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                                <Border Width="8" Height="60" CornerRadius="4" Background="#1A365D" Margin="0,0,15,0" VerticalAlignment="Bottom"/>
                                <Border Width="8" Height="40" CornerRadius="4" Background="#1A365D" Margin="0,0,15,0" VerticalAlignment="Bottom"/>
                                <Border Width="8" Height="80" CornerRadius="4" Background="#1954D1" Margin="0,0,15,0" VerticalAlignment="Bottom"/>
                                <Border Width="8" Height="90" CornerRadius="4" Background="#1A365D" Margin="0,0,15,0" VerticalAlignment="Bottom"/>
                                <Border Width="8" Height="50" CornerRadius="4" Background="#1A365D" Margin="0,0,15,0" VerticalAlignment="Bottom"/>
                                <Border Width="8" Height="30" CornerRadius="4" Background="#1A365D" Margin="0,0,15,0" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="20">
                    <StackPanel>
                        <TextBlock Text="September 2024" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Calendar View..." Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                <Border Background="White" CornerRadius="20" Height="250" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <TextBlock Text="Time tracker" FontSize="16" FontWeight="Medium" Foreground="#6B7280"/>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">
                            <Ellipse Width="120" Height="120" Stroke="#E5E7EB" StrokeThickness="10"/>
                            <Ellipse Width="120" Height="120" Stroke="#1954D1" StrokeThickness="10" StrokeDashArray="2.5 1"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="03:45" FontSize="24" FontWeight="Bold" Foreground="#1A1C29" HorizontalAlignment="Center"/>
                                <TextBlock Text="Work Time" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Background="#1A365D" CornerRadius="20" Padding="20" MinHeight="300">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Onboarding Task" FontSize="18" Foreground="White"/>
                            <TextBlock Text="3/8" FontSize="18" Foreground="White" HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Background="#2B4C84" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountTie" Foreground="#A0B9DF" Margin="0,0,15,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Client Meeting" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="Sep 15, 08:30" FontSize="11" Foreground="#A0B9DF"/>
                                    </StackPanel>
                                </StackPanel>
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4ADE80" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#2B4C84" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Pen" Foreground="#A0B9DF" Margin="0,0,15,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Design Review" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="Sep 15, 10:30" FontSize="11" Foreground="#A0B9DF"/>
                                    </StackPanel>
                                </StackPanel>
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4ADE80" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="#2B4C84" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Update" Foreground="#A0B9DF" Margin="0,0,15,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Project Update" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="Sep 15, 12:00" FontSize="11" Foreground="#A0B9DF"/>
                                    </StackPanel>
                                </StackPanel>
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4ADE80" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>