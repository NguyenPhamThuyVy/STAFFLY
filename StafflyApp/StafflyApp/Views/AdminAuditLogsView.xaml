<UserControl x:Class="StafflyApp.Views.AdminAuditLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:StafflyApp.ViewModels"
             Background="Transparent" FontFamily="Segoe UI">

    <UserControl.DataContext>
        <vm:AdminAuditLogsViewModel/>
    </UserControl.DataContext>

    <Border Background="White" CornerRadius="25" Padding="30" Margin="10,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="Security &amp; Audit Logs" FontSize="26" FontWeight="Bold" Foreground="#BE123C"/>
                    <TextBlock Text="Trace cryptographic footprints and monitor continuous runtime operations." Foreground="#6B7280" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <TextBox HorizontalAlignment="Right" Width="300" Height="42" VerticalAlignment="Center"
                         Text="{Binding SearchLogQuery, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="🔍 Search logs dynamically..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:TextFieldAssist.TextFieldCornerRadius="10"/>
            </Grid>

            <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredAuditLogs}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Style="{StaticResource MaterialDesignDataGrid}" BorderThickness="0" Background="White" RowHeight="40"
                      AlternatingRowBackground="#FAFBFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="170" Foreground="#6B7280"/>
                    <DataGridTextColumn Header="Operator User" Binding="{Binding Username}" Width="130" FontWeight="SemiBold" Foreground="#1A1C29"/>

                    <DataGridTextColumn Header="Action Type" Binding="{Binding ActionType}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="LOGIN">
                                        <Setter Property="Foreground" Value="#15803D"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="CREATE_USER">
                                        <Setter Property="Foreground" Value="#1954D1"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="APPROVE_PAYROLL">
                                        <Setter Property="Foreground" Value="#D97706"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Cryptographic Log Description / Context" Binding="{Binding LogDetail}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>