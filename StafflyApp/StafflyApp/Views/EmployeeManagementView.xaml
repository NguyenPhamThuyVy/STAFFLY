<UserControl x:Class="StafflyApp.Views.EmployeeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent" FontFamily="Segoe UI"
             KeyDown="UserControl_KeyDown">

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding OpenAddDialogCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding ConfirmActionCommand}"/>
    </UserControl.InputBindings>

    <materialDesign:DialogHost IsOpen="{Binding IsDialogOpen}" Identifier="MainDialog">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="30" Width="450" Background="White" CornerRadius="20">
                <StackPanel>
                    <Border Background="Transparent" 
                            Cursor="SizeAll" 
                            x:Name="DialogHeader"
                            PreviewMouseLeftButtonDown="DialogHeader_PreviewMouseLeftButtonDown">
                        <TextBlock Text="{Binding FormTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1954D1"/>
                    </Border>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransferMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBox materialDesign:HintAssist.Hint="Full Name" Text="{Binding EditingEmployee.FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,8" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="Email Address" Text="{Binding EditingEmployee.Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,8" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="Phone Number" Text="{Binding EditingEmployee.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,8" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <ComboBox materialDesign:HintAssist.Hint="Assign Department" 
                                  ItemsSource="{Binding Departments}" 
                                  DisplayMemberPath="DepartmentName"
                                  SelectedValuePath="DepartmentID"
                                  SelectedValue="{Binding EditingEmployee.DepartmentID, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,8"/>

                        <ComboBox materialDesign:HintAssist.Hint="Status" 
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding EditingEmployee.Status, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,8">
                            <ComboBoxItem Content="Active"/>
                            <ComboBoxItem Content="Probation"/>
                            <ComboBoxItem Content="Inactive"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransferMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Select target department for employee:" Margin="0,0,0,10" Foreground="#6B7280"/>
                        <ComboBox materialDesign:HintAssist.Hint="Target Department" 
                                  ItemsSource="{Binding Departments}" 
                                  DisplayMemberPath="DepartmentName"
                                  SelectedItem="{Binding SelectedTargetDept}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,10"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="CANCEL" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Content="CONFIRM" Command="{Binding ConfirmActionCommand}" Margin="10,0,0,0" Background="#1954D1" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <Border Background="White" CornerRadius="25" Padding="25" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Company Employees" FontSize="22" FontWeight="Bold" Foreground="#1A1C29" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#F3F4F6" CornerRadius="8" Padding="15,8" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total: " Foreground="#6B7280" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TotalEmployees}" Foreground="#1A1C29" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#ECFDF5" CornerRadius="8" Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Active: " Foreground="#10B981" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ActiveEmployees}" Foreground="#10B981" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Width="280" materialDesign:HintAssist.Hint="Search employees..." 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="2" Content="+ Add Employee" Command="{Binding OpenAddDialogCommand}" 
                            Background="#1954D1" Foreground="White" BorderThickness="0" Height="40" Padding="15,0"
                            materialDesign:ButtonAssist.CornerRadius="10"/>
                </Grid>

                <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ID" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="EMPLOYEE" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" Margin="52,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="PHONE" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="EMAIL" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="DEPARTMENT" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="ACTIONS" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,35,0"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Employees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="15,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding EmployeeID}" VerticalAlignment="Center" Foreground="#6B7280" FontWeight="Medium"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="36" Height="36" CornerRadius="18" Background="#E0E7FF" Margin="0,0,12,0">
                                                <materialDesign:PackIcon Kind="Account" Foreground="#1954D1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" Height="20"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FullName}" Foreground="#1A1C29" FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#10B981" FontWeight="Medium"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Phone}" VerticalAlignment="Center" Foreground="#4B5563"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Email}" VerticalAlignment="Center" Foreground="#4B5563"/>
                                        <TextBlock Grid.Column="4" Text="{Binding DepartmentName}" VerticalAlignment="Center" Foreground="#4B5563"/>
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Transfer" Height="32" Width="32" 
                                                    Command="{Binding DataContext.OpenTransferDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="SwapHorizontal" Foreground="#1954D1"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Edit" Height="32" Width="32" Margin="4,0"
                                                    Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="PencilOutline" Foreground="#6B7280"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Delete" Height="32" Width="32"
                                                    Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Foreground="#EF4444"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </materialDesign:DialogHost>
</UserControl>