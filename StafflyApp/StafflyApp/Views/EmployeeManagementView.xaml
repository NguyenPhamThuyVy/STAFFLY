<UserControl x:Class="StafflyApp.Views.EmployeeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent" FontFamily="Segoe UI">

    <materialDesign:DialogHost IsOpen="{Binding IsDialogOpen}" Identifier="MainDialog">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="30" Width="420" Background="White" CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1954D1"/>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransferMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBox materialDesign:HintAssist.Hint="Full Name" Text="{Binding EditingEmployee.FullName}" Margin="0,10" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="Email Address" Text="{Binding EditingEmployee.Email}" Margin="0,10" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox materialDesign:HintAssist.Hint="Phone Number" Text="{Binding EditingEmployee.Phone}" Margin="0,10" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransferMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Select target department for employee:" Margin="0,0,0,10" Foreground="#6B7280"/>
                        <ComboBox materialDesign:HintAssist.Hint="Department" 
                                  ItemsSource="{Binding Departments}" 
                                  DisplayMemberPath="DepartmentName"
                                  SelectedItem="{Binding SelectedTargetDept}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,10"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="CANCEL" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Content="CONFIRM" Command="{Binding ConfirmActionCommand}" Margin="10,0,0,0" Background="#1954D1" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <Border Background="White" CornerRadius="25" Padding="25" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Company Employees" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1A1C29"/>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Width="300" HorizontalAlignment="Left" materialDesign:HintAssist.Hint="Search employees..." 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <Button Grid.Column="1" Content="+ Add Employee" Command="{Binding OpenAddDialogCommand}" 
                            Background="#1954D1" Foreground="White" BorderThickness="0" Height="40"
                            materialDesign:ButtonAssist.CornerRadius="10"/>
                </Grid>

                <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="8" Padding="15,12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="ID" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="EMPLOYEE" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="EMAIL" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="DEPARTMENT" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="ACTIONS" Foreground="#9CA3AF" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,35,0"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Employees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="15,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding EmployeeID}" VerticalAlignment="Center" Foreground="#6B7280" FontWeight="Medium"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" Foreground="#1A1C29" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#10B981" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{Binding Email}" VerticalAlignment="Center" Foreground="#4B5563"/>

                                        <TextBlock Grid.Column="3" Text="{Binding DepartmentName}" VerticalAlignment="Center" Foreground="#4B5563"/>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                    ToolTip="Transfer Department" Height="32" Width="32" Padding="0"
                                                    Command="{Binding DataContext.OpenTransferDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="SwapHorizontal" Foreground="#1954D1"/>
                                            </Button>

                                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                    ToolTip="Edit Employee" Height="32" Width="32" Padding="0" Margin="4,0"
                                                    Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="PencilOutline" Foreground="#6B7280"/>
                                            </Button>

                                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                                    ToolTip="Delete Employee" Height="32" Width="32" Padding="0"
                                                    Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Foreground="#EF4444"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </materialDesign:DialogHost>
</UserControl>