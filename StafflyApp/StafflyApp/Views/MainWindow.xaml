<Window x:Class="StafflyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:StafflyApp.Views" 
        Title="STAFFLY - Dashboard" Height="768" Width="1200"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown" FontFamily="Segoe UI">

    <Border CornerRadius="20" Background="#F4F7FE" BorderThickness="1" BorderBrush="#E0E0E0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF2945FF" CornerRadius="20,60,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="30,50,20,40">
                        <Border Width="80" Height="80" CornerRadius="40" Background="White" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <Image Source="/Assets/Images/staffly_logo.png" 
                                   Width="55" Height="55" 
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="STAFFLY" FontSize="26" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Intelligent HR Portal" FontSize="13" Foreground="#D1C4E9" Margin="0,2,0,0" Opacity="0.8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="20,0,20,0">

                        <Border x:Name="MenuBorder_Dashboard" Background="Transparent" CornerRadius="10" Margin="0,5">
                            <Button Click="MenuDashboard_Click" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Height="50">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="HomeOutline" Width="24" Height="24" Foreground="White" Margin="0,0,15,0"/>
                                    <TextBlock Text="Dashboard" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border x:Name="MenuBorder_Employees" Background="Transparent" CornerRadius="10" Margin="0,5">
                            <Button Click="MenuEmployees_Click" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Height="50">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24" Foreground="White" Margin="0,0,15,0"/>
                                    <TextBlock Text="Employees" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border x:Name="MenuBorder_Attendance" Background="Transparent" CornerRadius="10" Margin="0,5">
                            <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Height="50">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CalendarCheckOutline" Width="24" Height="24" Foreground="White" Margin="0,0,15,0"/>
                                    <TextBlock Text="Attendance" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border x:Name="MenuBorder_Payroll" Background="Transparent" CornerRadius="10" Margin="0,5">
                            <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Height="50">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="WalletOutline" Width="24" Height="24" Foreground="White" Margin="0,0,15,0"/>
                                    <TextBlock Text="Payroll" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border x:Name="MenuBorder_Contracts" Background="Transparent" CornerRadius="10" Margin="0,5">
                            <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Height="50">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileDocumentOutline" Width="24" Height="24" Foreground="White" Margin="0,0,15,0"/>
                                    <TextBlock Text="Contracts" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border x:Name="MenuBorder_Departments" Background="Transparent" CornerRadius="10" Margin="0,5">
                            <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Height="50">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Domain" Width="24" Height="24" Foreground="White" Margin="0,0,15,0"/>
                                    <TextBlock Text="Departments" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </StackPanel>

                    <Button Grid.Row="2" Click="Logout_Click" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Margin="20,0,20,30" Height="50">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="24" Height="24" Foreground="#D1C4E9" Margin="0,0,15,0"/>
                            <TextBlock Text="Logout" FontSize="16" Foreground="#D1C4E9" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="40,30,40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="20" HorizontalAlignment="Left" Width="350" Height="45" Padding="15,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Search here..." BorderThickness="0" VerticalAlignment="Center" FontSize="15" Background="Transparent"/>
                            <materialDesign:PackIcon Grid.Column="1" Kind="Magnify" Foreground="#A0A0A0" Width="20" Height="20" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Background="White" BorderThickness="0" Width="40" Height="40" materialDesign:ButtonAssist.CornerRadius="20" Padding="0" Margin="0,0,10,0">
                            <materialDesign:PackIcon Kind="BellOutline" Foreground="#757575"/>
                        </Button>
                        <Button Background="White" BorderThickness="0" Width="40" Height="40" materialDesign:ButtonAssist.CornerRadius="20" Padding="0" Margin="0,0,20,0">
                            <materialDesign:PackIcon Kind="CogOutline" Foreground="#757575"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Width="40" Height="40" Padding="0" Click="CloseButton_Click" Cursor="Hand">
                            <materialDesign:PackIcon Kind="Close" Foreground="#757575" Width="24" Height="24"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <ContentControl x:Name="MainContentArea" Grid.Row="1"/>
            </Grid>
        </Grid>
    </Border>
</Window>