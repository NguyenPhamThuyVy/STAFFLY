<Window x:Class="StafflyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="STAFFLY" Height="800" Width="1300"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown" FontFamily="Segoe UI">

    <Border CornerRadius="30" Background="#F0F4F8" BorderThickness="1" BorderBrush="#E0E0E0" Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="STAFFLY" FontSize="24" FontWeight="ExtraBold" Foreground="#1954D1" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Border x:Name="TabDashboard" Background="#1954D1" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabDashboard_Click">
                        <TextBlock x:Name="TextDashboard" Text="Dashboard" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    </Border>

                    <Border x:Name="TabEmployees" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabEmployees_Click">
                        <TextBlock x:Name="TextEmployees" Text="Employees" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                    </Border>

                    <Border x:Name="TabDepartments" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabDepartments_Click">
                        <TextBlock x:Name="TextDepartments" Text="Departments" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                    </Border>

                    <Border x:Name="TabAttendance" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabAttendance_Click">
                        <TextBlock x:Name="TextAttendance" Text="Attendance" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                    </Border>

                    <Border x:Name="TabPayroll" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabPayroll_Click">
                        <TextBlock x:Name="TextPayroll" Text="Payroll" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                    </Border>

                    <Border x:Name="TabRecruitment" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabRecruitment_Click">
                        <TextBlock x:Name="TextRecruitment" Text="Recruitment" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                    </Border>

                    <Border x:Name="TabContracts" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabContracts_Click">
                        <TextBlock x:Name="TextContracts" Text="Contracts" Foreground="#6B7280" FontSize="14" FontWeight="Medium"/>
                    </Border>

                    <Border x:Name="TabSystem" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="TabSystem_Click">
                        <TextBlock x:Name="TextSystem" Text="System" Foreground="#FF6B7280" FontSize="14" FontWeight="Medium"/>
                    </Border>

                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" Background="White" BorderThickness="0" Width="35" Height="35" Margin="0,0,10,0" materialDesign:ElevationAssist.Elevation="Dp2">
                        <materialDesign:PackIcon Kind="CogOutline" Foreground="#6B7280"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" Background="White" BorderThickness="0" Width="35" Height="35" Margin="0,0,15,0" materialDesign:ElevationAssist.Elevation="Dp2">
                        <materialDesign:PackIcon Kind="AccountOutline" Foreground="#6B7280"/>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Padding="0" Click="CloseButton_Click" Cursor="Hand" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Close" Foreground="#6B7280" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Grid>

            <ContentControl x:Name="MainContentArea" Grid.Row="1" />
        </Grid>
    </Border>
</Window>