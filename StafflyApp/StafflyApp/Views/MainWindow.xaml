<Window x:Class="StafflyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:StafflyApp.ViewModels"
        xmlns:v="clr-namespace:StafflyApp.Views"
        Title="STAFFLY" Height="800" Width="1300"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown" FontFamily="Segoe UI">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeeViewModel}">
            <v:EmployeeManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DepartmentViewModel}">
            <v:DepartmentView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayrollViewModel}">
            <v:PayrollView/>
        </DataTemplate>

        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="Transparent" CornerRadius="18" Padding="20,8" Margin="5,0" Cursor="Hand">
                            <TextBlock x:Name="TabText" Text="{TemplateBinding Content}" FontSize="14" FontWeight="Medium" Foreground="#6B7280"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1954D1"/>
                                <Setter TargetName="TabText" Property="Foreground" Value="White"/>
                                <Setter TargetName="TabText" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog">
        <Border CornerRadius="30" Background="#F0F4F8" BorderThickness="1" BorderBrush="#E0E0E0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="STAFFLY" FontSize="24" FontWeight="ExtraBold" Foreground="#1954D1" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <RadioButton Content="Dashboard" Style="{StaticResource TabButtonStyle}" 
                                     IsChecked="True" Click="TabDashboard_Click"/>

                        <RadioButton Content="Employees" Style="{StaticResource TabButtonStyle}" 
                                     Click="TabEmployees_Click"/>

                        <RadioButton Content="Departments" Style="{StaticResource TabButtonStyle}" 
                                     Click="TabDepartments_Click"/>

                        <RadioButton Content="Payroll" Style="{StaticResource TabButtonStyle}" 
                                     Click="TabPayroll_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" Background="White" BorderThickness="0" Width="35" Height="35" Margin="0,0,10,0" materialDesign:ElevationAssist.Elevation="Dp2">
                            <materialDesign:PackIcon Kind="SettingsOutline" Foreground="#6B7280"/>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" Background="White" BorderThickness="0" Width="35" Height="35" Margin="0,0,15,0" materialDesign:ElevationAssist.Elevation="Dp2">
                            <materialDesign:PackIcon Kind="AccountOutline" Foreground="#6B7280"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Click="CloseButton_Click" Cursor="Hand" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Close" Foreground="#6B7280" Width="24" Height="24"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <materialDesign:TransitioningContent Content="{Binding CurrentView}" Grid.Row="1" Focusable="False">
                    <materialDesign:TransitioningContent.OpeningEffect>
                        <materialDesign:TransitionEffect Kind="FadeIn" Duration="0:0:0.3"/>
                    </materialDesign:TransitioningContent.OpeningEffect>
                </materialDesign:TransitioningContent>
            </Grid>
        </Border>
    </materialDesign:DialogHost>
</Window>