<UserControl x:Class="StafflyApp.Views.DepartmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Border Background="White" CornerRadius="25" Padding="30" Margin="10,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Department Structure" FontSize="26" FontWeight="Bold" Foreground="#1A1C29"/>
                <TextBlock Text="Manage organizational hierarchy and headcount limits" Foreground="#6B7280" FontSize="14"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Departments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F9FAFB" Width="280" Height="160" CornerRadius="20" Margin="0,0,20,20" Padding="20">
                                <Grid>
                                    <StackPanel>
                                        <materialDesign:PackIcon Kind="Domain" Foreground="#1954D1" Width="24" Height="24"/>
                                        <TextBlock Text="{Binding DepartmentName}" FontSize="18" FontWeight="Bold" Margin="0,10,0,5"/>

                                        <Grid Margin="0,10,0,5">
                                            <TextBlock HorizontalAlignment="Left" FontSize="12" Foreground="#6B7280">
                                                <Run Text="Staff: "/>
                                                <Run Text="{Binding CurrentStaffCount}" FontWeight="Bold" Foreground="#1A1C29"/>
                                                <Run Text="/"/>
                                                <Run Text="{Binding HeadcountLimit}"/>
                                            </TextBlock>
                                        </Grid>

                                        <ProgressBar Maximum="{Binding HeadcountLimit}" Value="{Binding CurrentStaffCount}" 
                                                     Height="8" Foreground="#1954D1" Background="#E5E7EB" BorderThickness="0"/>
                                    </StackPanel>

                                    <Button VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{Binding DataContext.OpenTransferDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" Content="TRANSFER"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>