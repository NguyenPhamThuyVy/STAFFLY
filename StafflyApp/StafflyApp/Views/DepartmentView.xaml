<UserControl x:Class="StafflyApp.Views.DepartmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Border Background="White" CornerRadius="25" Padding="30" Margin="10,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Department Structure" FontSize="26" FontWeight="Bold" Foreground="#1A1C29"/>
                <TextBlock Text="Manage organizational hierarchy and headcount limits" Foreground="#6B7280" FontSize="14" Margin="0,5,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Departments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Width="280" Height="190" CornerRadius="16" Margin="0,0,25,25" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#D1D5DB" Opacity="0.4"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <Border Background="#E0E7FF" Width="40" Height="40" CornerRadius="20" HorizontalAlignment="Left">
                                            <materialDesign:PackIcon Kind="Domain" Foreground="#1954D1" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="{Binding DepartmentName}" FontSize="18" FontWeight="Bold" Foreground="#1A1C29" Margin="0,15,0,5"/>

                                        <Grid Margin="0,5,0,10">
                                            <TextBlock HorizontalAlignment="Left" FontSize="13" Foreground="#6B7280">
                                                <Run Text="Staff: "/>
                                                <Run Text="{Binding Employees.Count, Mode=OneWay}" FontWeight="Bold" Foreground="#1954D1"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding HeadcountLimit}"/>
                                            </TextBlock>
                                        </Grid>

                                        <ProgressBar Maximum="{Binding HeadcountLimit}" 
                                                     Value="{Binding Employees.Count, Mode=OneWay}" 
                                                     Height="6" Foreground="#1954D1" Background="#F3F4F6" BorderThickness="0"/>
                                    </StackPanel>

                                    <Button Grid.Row="1" 
                                            HorizontalAlignment="Right" 
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{Binding DataContext.OpenTransferDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" 
                                            Content="TRANSFER" 
                                            Foreground="#1954D1" 
                                            FontWeight="Bold" 
                                            Margin="0,10,-10,-10"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>