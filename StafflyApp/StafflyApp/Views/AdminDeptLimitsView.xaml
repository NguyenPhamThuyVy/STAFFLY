<UserControl x:Class="StafflyApp.Views.AdminDeptLimitsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:StafflyApp.ViewModels"
             Background="Transparent" FontFamily="Segoe UI">

    <UserControl.DataContext>
        <vm:AdminDeptLimitsViewModel/>
    </UserControl.DataContext>

    <Border Background="White" CornerRadius="25" Padding="30" Margin="10,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Department Capacity Limits" FontSize="26" FontWeight="Bold" Foreground="#1A365D"/>
                <TextBlock Text="Establish organizational metrics and restrict maximum active workforce sizes." Foreground="#6B7280" FontSize="14" Margin="0,5,0,0"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding DepartmentsBoundaries}" AutoGenerateColumns="False" CanUserAddRows="False"
                      Style="{StaticResource MaterialDesignDataGrid}" BorderThickness="0" Background="White" RowHeight="48">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dept ID" Binding="{Binding DepartmentID}" IsReadOnly="True" Width="100"/>
                    <DataGridTextColumn Header="Department Organizational Unit Name" Binding="{Binding DepartmentName}" IsReadOnly="True" Width="400" FontWeight="SemiBold" Foreground="#1A1C29"/>

                    <DataGridTextColumn Header="Headcount Limit (Double-click Cell to Edit)" 
                                        Binding="{Binding HeadcountLimit, UpdateSourceTrigger=LostFocus}" 
                                        Width="*" Foreground="#1954D1" FontWeight="Bold">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="20,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>